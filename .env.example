# Model paths
MODEL_PATH=models/saved/model.pkl
BASELINE_MODEL_PATH=models/saved/chainladder_baseline.pkl

# Data directories
DATA_DIR=data/
RAW_DATA_DIR=data/raw/
PROCESSED_DATA_DIR=data/processed/

# API configuration
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO

# Feature engineering
NORMALIZE_FEATURES=true

# Model evaluation
DIVERGENCE_THRESHOLD=0.15
COVERAGE_TARGET_80=0.80
COVERAGE_TARGET_90=0.90

# Training hyperparameters (adjust per architecture choice)
VAL_SPLIT=0.2
RANDOM_SEED=42
